From dea4ac1e3e4c4db9e53771223a8a968755fa5eac Mon Sep 17 00:00:00 2001
From: zkmike <zkmike@gmail.com>
Date: Thu, 23 Apr 2026 08:47:44 -0700
Subject: [PATCH 4/5] Add tc358743 camera CAM0 CN7

---
 .../dts/renesas/r9a09g056n48-rzv2n-evk.dts    | 38 +++++++++++++++++++
 1 file changed, 38 insertions(+)

diff --git a/arch/arm64/boot/dts/renesas/r9a09g056n48-rzv2n-evk.dts b/arch/arm64/boot/dts/renesas/r9a09g056n48-rzv2n-evk.dts
index de4f74899..99d84dd39 100644
--- a/arch/arm64/boot/dts/renesas/r9a09g056n48-rzv2n-evk.dts
+++ b/arch/arm64/boot/dts/renesas/r9a09g056n48-rzv2n-evk.dts
@@ -482,6 +482,35 @@ &i2c0 {
 	pinctrl-names = "default";
 	clock-frequency = <400000>;
 	status = "okay";
+
+	tc358743_csi20: tc358743_csi20@f {
+
+	    /* TC358743 SPECIFIC - must match driver exactly */
+	    compatible = "toshiba,tc358743";
+		reg = <0x0f>;
+
+	    clock-names = "refclk";					// TC358743 Specific name
+	    dovdd-supply = <&tc358743_dovdd_1v8>;		// TC358743 Specific supply names
+	    avdd-supply = <&tc358743_avdd_3v3>;	// TC358743 Specific supply names  
+	    dvdd-supply = <&tc358743_dvdd_1v2>;		// TC358743 Specific supply names
+	    
+	    /* STANDARD properties (but TC358743-specific values) */
+	    clocks = <&tc358743_clk>;
+	    clock-frequency = <27000000>;  // HDMI typical frequency
+	    reset-gpios = <&pinctrl RZG2L_GPIO(6, 4) GPIO_ACTIVE_LOW>;
+
+	    port {
+	        tc358743_to_csi20: endpoint {
+	            /* STANDARD CSI-2 properties */
+	            clock-lanes = <0>;
+	            data-lanes = <1 2 3 4>;
+	            remote-endpoint = <&csi20_in>;
+	            
+	            /* TC358743 commonly uses this */
+	            link-frequencies = /bits/ 64 <297000000>;
+	        };
+	    };
+	};
 };
 
 &i2c1 {
@@ -1231,6 +1260,15 @@ &cru0 {
 &csi20 {
 	status = "okay";
 
+	ports {
+		port {
+			csi20_in: endpoint {
+				clock-lanes = <0>;
+				data-lanes = <1 2 3 4>;
+				remote-endpoint = <&tc358743_to_csi20>;
+			};
+		};
+	};
 };
 
 &cru1 {
-- 
2.25.1

